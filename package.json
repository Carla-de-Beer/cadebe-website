    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "stylelint": "^16.6.1",
    "stylelint-config-sass-guidelines": "^11.1.0",
